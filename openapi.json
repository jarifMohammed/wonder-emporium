  "info": {
    "title": "NestJS API",
    "description": "Production-ready NestJS API with Prisma, PostgreSQL, Authentication, Logging, Monitoring, and more.",
    "version": "1.0.0",
    "contact": {}
  },
  "tags": [
    {
      "name": "auth",
      "description": "Authentication and authorization endpoints"
    },
    {
      "name": "health",
      "description": "Health check endpoints"
    },
    {
      "name": "metrics",
      "description": "Metrics and monitoring endpoints"
    }
  ],
  "servers": [],
  "components": {
    "securitySchemes": {
      "JWT-auth": {
        "scheme": "bearer",
        "bearerFormat": "JWT",
        "type": "http",
        "name": "JWT",
        "description": "Enter JWT access token",
        "in": "header"
      }
    },
    "schemas": {
      "ContactDto": {
        "type": "object",
        "properties": {}
      },
      "RegisterRequest": {
        "type": "object",
        "properties": {
          "firstName": {
            "type": "string",
            "example": "John"
          },
          "lastName": {
            "type": "string",
            "example": "Doe"
          },
          "email": {
            "type": "string",
            "example": "john@example.com"
          },
          "password": {
            "type": "string",
            "example": "StrongPass123!"
          },
          "role": {
            "type": "string",
            "enum": [
              "USER",
              "ADMIN",
              "MODERATOR",
              "SUPERADMIN",
              "READER",
              "AUTHOR"
            ],
            "example": "READER"
          }
        },
        "required": [
          "firstName",
          "lastName",
          "email",
          "password",
          "role"
        ]
      },
      "LoginRequest": {
        "type": "object",
        "properties": {
          "email": {
            "type": "string",
            "example": "john@example.com"
          },
          "password": {
            "type": "string",
            "example": "StrongPass123!"
          }
        },
        "required": [
          "email",
          "password"
        ]
      },
      "ForgotPasswordRequest": {
        "type": "object",
        "properties": {
          "email": {
            "type": "string",
            "example": "john@example.com"
          }
        },
        "required": [
          "email"
        ]
      },
      "ResetPasswordRequest": {
        "type": "object",
        "properties": {
          "email": {
            "type": "string",
            "example": "john@example.com"
          },
          "otp": {
            "type": "string",
            "example": "123456"
          },
          "password": {
            "type": "string",
            "example": "NewStrongPass123!"
          }
        },
        "required": [
          "email",
          "otp",
          "password"
        ]
      },
      "ChangePasswordRequest": {
        "type": "object",
        "properties": {
          "oldPassword": {
            "type": "string",
            "example": "OldPass123!"
          },
          "newPassword": {
            "type": "string",
            "example": "NewPass123!"
          }
        },
        "required": [
          "oldPassword",
          "newPassword"
        ]
      },
      "RefreshTokenRequest": {
        "type": "object",
        "properties": {
          "refreshToken": {
            "type": "string"
          }
        },
        "required": [
          "refreshToken"
        ]
      },
      "VerifyEmailRequest": {
        "type": "object",
        "properties": {
          "email": {
            "type": "string",
            "example": "john@example.com"
          },
          "code": {
            "type": "string",
            "example": "123456"
          }
        },
        "required": [
          "email",
          "code"
        ]
      },
      "GoogleTokenRequest": {
        "type": "object",
        "properties": {
          "idToken": {
            "type": "string",
            "description": "Google ID token from Google Sign-In"
          }
        },
        "required": [
          "idToken"
        ]
      },
      "BookFormatDto": {
        "type": "object",
        "properties": {
          "formatType": {
            "type": "string",
            "example": "EBOOK"
          },
          "listPrice": {
            "type": "number",
            "example": 9.99
          },
          "sku": {
            "type": "string",
            "example": "SKU-123"
          },
          "pageCount": {
            "type": "number",
            "example": 320
          },
          "trimSize": {
            "type": "string",
            "example": "6x9"
          },
          "coverUrl": {
            "type": "string",
            "example": "https://..."
          },
          "interiorUrl": {
            "type": "string",
            "example": "https://..."
          }
        },
        "required": [
          "formatType",
          "listPrice"
        ]
      },
      "CreateBookRequest": {
        "type": "object",
        "properties": {
          "title": {
            "type": "string",
            "example": "The Great Adventure"
          },
          "description": {
            "type": "string",
            "example": "A thrilling adventure story..."
          },
          "isbn": {
            "type": "string",
            "example": "978-3-16-148410-0"
          },
          "category": {
            "type": "string",
            "example": "Fiction"
          },
          "tags": {
            "example": [
              "adventure",
              "fiction",
              "thriller"
            ],
            "type": "array",
            "items": {
              "type": "string"
            }
          },
          "language": {
            "type": "string",
            "example": "English"
          },
          "ageGroup": {
            "type": "string",
            "example": "Adult"
          },
          "formats": {
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/BookFormatDto"
            }
          },
          "authorEarnings": {
            "type": "number",
            "example": 7
          },
          "publicationDetails": {
            "type": "string",
            "example": "Published by Wonder Press, 2024"
          }
        },
        "required": [
          "title"
        ]
      },
      "UpdateBookRequest": {
        "type": "object",
        "properties": {
          "title": {
            "type": "string",
            "example": "The Great Adventure"
          },
          "description": {
            "type": "string",
            "example": "A thrilling adventure story..."
          },
          "isbn": {
            "type": "string",
            "example": "978-3-16-148410-0"
          },
          "category": {
            "type": "string",
            "example": "Fiction"
          },
          "tags": {
            "example": [
              "adventure",
              "fiction"
            ],
            "type": "array",
            "items": {
              "type": "string"
            }
          },
          "language": {
            "type": "string",
            "example": "English"
          },
          "ageGroup": {
            "type": "string",
            "example": "Adult"
          },
          "formats": {
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/BookFormatDto"
            }
          },
          "authorEarnings": {
            "type": "number",
            "example": 7
          },
          "publicationDetails": {
            "type": "string",
            "example": "Published by Wonder Press, 2024"
          }
        }
      },
      "ApproveBookRequest": {
        "type": "object",
        "properties": {
          "status": {
            "type": "string",
            "enum": [
              "DRAFT",
              "SUBMITTED",
              "APPROVED",
              "REJECTED"
            ],
            "example": "APPROVED"
          }
        },
        "required": [
          "status"
        ]
      },
      "CreateCheckoutDto": {
        "type": "object",
        "properties": {}
      }
    }
  }
