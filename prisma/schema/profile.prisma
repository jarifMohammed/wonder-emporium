// ================================
// User Profile Model
// ================================

model UserProfile {
  id            String   @id @default(uuid()) @db.Uuid
  authId        String   @unique @db.Uuid
  firstName     String?
  lastName      String?
  bio           String?
  avatarUrl     String?
  coverImageUrl String?
  websiteUrl    String?
  twitterUrl    String?
  instagramUrl  String?
  linkedinUrl   String?
  location      String?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  // Relations
  authUser AuthUser @relation(fields: [authId], references: [id], onDelete: Cascade)

  // @unique on authId already creates an index — no @@index needed
}
