// ================================
// Order & OrderItem Models
// ================================

model Order {
  id              String      @id @default(uuid()) @db.Uuid
  buyerId         String      @db.Uuid
  stripeSessionId       String      @unique
  stripePaymentIntentId String?     @unique
  status          OrderStatus @default(PENDING)
  currency        String      @default("USD")
  subtotal        Float       @default(0)
  taxAmount       Float       @default(0)
  totalAmount     Float       @default(0)
  createdAt       DateTime    @default(now())
  updatedAt       DateTime    @updatedAt

  buyer     AuthUser             @relation(fields: [buyerId], references: [id])
  items     OrderItem[]
  payouts   AuthorOrderPayout[]
  printCost Float?
  printJob  Json?

  @@index([buyerId])
  @@index([status])
}

model OrderItem {
  id         String   @id @default(uuid()) @db.Uuid
  orderId    String   @db.Uuid
  bookId     String   @db.Uuid
  formatId   String   @db.Uuid
  authorId   String   @db.Uuid
  unitPrice  Float
  quantity   Int
  taxAmount  Float    @default(0)
  totalPrice Float
  createdAt  DateTime @default(now())

  order  Order             @relation(fields: [orderId], references: [id], onDelete: Cascade)
  book   Book              @relation(fields: [bookId], references: [id])
  format BookFormatPricing @relation(fields: [formatId], references: [id])

  @@index([orderId])
  @@index([authorId])
}

model AuthorOrderPayout {
  id               String       @id @default(uuid()) @db.Uuid
  orderId          String       @db.Uuid
  authorId         String       @db.Uuid
  amount           Float
  platformFee      Float
  status           PayoutStatus @default(PENDING_REQUEST)
  stripeTransferId String?
  createdAt        DateTime     @default(now())
  updatedAt        DateTime     @updatedAt

  order  Order    @relation(fields: [orderId], references: [id], onDelete: Cascade)
  author AuthUser @relation(fields: [authorId], references: [id], onDelete: Cascade)

  @@unique([orderId, authorId])
  @@index([authorId])
  @@index([status])
}

// ================================
// Cart & CartItem Models
// ================================

model Cart {
  id        String     @id @default(uuid()) @db.Uuid
  userId    String     @unique @db.Uuid
  createdAt DateTime   @default(now())
  updatedAt DateTime   @updatedAt

  user  AuthUser  @relation(fields: [userId], references: [id], onDelete: Cascade)
  items CartItem[]
}

model CartItem {
  id        String   @id @default(uuid()) @db.Uuid
  cartId    String   @db.Uuid
  bookId    String   @db.Uuid
  formatId  String   @db.Uuid
  quantity  Int      @default(1)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  cart   Cart              @relation(fields: [cartId], references: [id], onDelete: Cascade)
  book   Book              @relation(fields: [bookId], references: [id])
  format BookFormatPricing @relation(fields: [formatId], references: [id])

  @@index([cartId])
  @@index([bookId])
  @@unique([cartId, bookId, formatId])
}
