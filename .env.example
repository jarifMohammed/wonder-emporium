# PostgreSQL Connection
# Format: postgresql://<username>:<password>@<host>:<port>/<database>?schema=<schema>
# For local dev: postgresql://postgres:postgres@localhost:5432/wonder_emporium?schema=public
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/wonder_emporium?schema=public"

NODE_ENV=development

PORT=5000

JWT_SECRET=a-string-secret-at-least-256-bits-long

# Redis Configuration
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_USER=default
REDIS_PASSWORD=your_redis_password

# Email Configuration
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USER=your-email@gmail.com
EMAIL_PASS=your-app-password
EMAIL_FROM=noreply@yourapp.com

# Google OAuth Configuration
# Get these from Google Cloud Console: https://console.cloud.google.com/apis/credentials
GOOGLE_CLIENT_ID=your-google-client-id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your-google-client-secret
GOOGLE_REDIRECT_URI=http://localhost:5000/auth/google/callback

# ── Stripe ─────────────────────────────────────────────────────────────────────
# Your Stripe secret key (sk_live_... in production, sk_test_... for test mode)
STRIPE_SECRET_KEY=sk_test_your_stripe_secret_key

# Webhook signing secret for STANDARD checkout events
# Register: Dashboard → Developers → Webhooks → "Add endpoint"
# URL:       https://your-api.com/webhooks/stripe
# Events:    checkout.session.completed
STRIPE_WEBHOOK_SECRET=whsec_your_checkout_webhook_secret

# Webhook signing secret for CONNECT account events
# Register: Dashboard → Developers → Webhooks → "Add endpoint" (choose "Connect" type)
# URL:       https://your-api.com/webhooks/stripe/connect
# Events:    account.updated, capability.updated, account.application.deauthorized
STRIPE_CONNECT_WEBHOOK_SECRET=whsec_your_connect_webhook_secret

# ── Platform URLs ───────────────────────────────────────────────────────────────
# Base URL of your frontend (used for Stripe Connect onboarding redirect URLs)
APP_FRONTEND_URL=http://localhost:3000
# Path Stripe redirects to if the author needs to restart onboarding
STRIPE_CONNECT_REFRESH_PATH=/onboarding/refresh
# Path Stripe redirects to after the author completes onboarding
STRIPE_CONNECT_RETURN_PATH=/onboarding/complete
